{
  "expo": {
    "name": "Maison verte",
    "slug": "maison-verte",
    "version": "1.0.0",
    "orientation": "portrait",
    "jsEngine": "jsc",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Maison Verte utilise la camera pour ajouter une photo a vos plantes."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Maison Verte utilise votre position pour afficher la meteo locale de vos plantes."
        }
      ]
    ]
  }
}
